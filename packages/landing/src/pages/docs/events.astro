---
const schema = [
  { field: 'blob1', content: 'Page path' },
  { field: 'blob2', content: 'Referrer hostname (direct if none)' },
  { field: 'blob3', content: 'Country code (from CF headers)' },
  { field: 'blob4', content: 'Event name (pageview, timing, scroll_depth, custom)' },
  { field: 'blob5', content: 'Event properties (pipe-separated values)' },
  { field: 'blob6', content: 'utm_source' },
  { field: 'blob7', content: 'utm_medium' },
  { field: 'blob8', content: 'utm_campaign' },
  { field: 'blob9', content: 'Visitor hash (daily-rotating SHA-256)' },
  { field: 'blob10', content: 'Site hostname — required in all WHERE clauses' },
  { field: 'blob11', content: 'Device type (mobile / tablet / desktop)' },
  { field: 'blob12', content: 'Browser name (Chrome / Firefox / Safari / Edge / Other)' },
  { field: 'double1', content: 'Event count (always 1)' },
  { field: 'double2', content: 'Time on page in seconds (timing events only — use AVG)' },
];

const builtins = [
  { name: 'pageview', trigger: 'Every page load', fields: 'path, referrer, country, device, browser, UTM params' },
  { name: 'outbound', trigger: 'External link click', fields: 'path, destination URL (blob5)' },
  { name: 'timing', trigger: 'visibilitychange (tab close/switch)', fields: 'path, seconds on page (double2)' },
  { name: 'scroll_depth', trigger: '25 / 50 / 75 / 100% scroll milestone', fields: 'path, depth percentage (blob5)' },
];
---

