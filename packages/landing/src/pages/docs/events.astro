    .data-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border); color: var(--ink2); vertical-align: top; }
    .data-table tr:last-child td { border-bottom: none; }
    .field-name { font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--ink); }
    .event-name { font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--accent-text); }
    .code-block { background: #1c1917; border-radius: 6px; overflow: hidden; margin: 1rem 0; }
    .code-header { padding: 0.4rem 1rem; background: #292524; display: flex; align-items: center; gap: 0.5rem; }
