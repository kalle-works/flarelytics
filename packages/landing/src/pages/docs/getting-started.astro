    .sidebar { position: sticky; top: 1.5rem; }
    .sidebar-label { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink3); margin-bottom: 0.75rem; }
    .sidebar nav { padding: 0; border: none; }
    .sidebar nav a { display: block; font-family: var(--mono); font-size: 12px; color: var(--ink2); padding: 5px 0; border-left: 2px solid transparent; padding-left: 10px; }
    .sidebar nav a:hover { color: var(--ink); border-left-color: var(--border); }
    .sidebar nav a.active { color: var(--accent-text); border-left-color: var(--accent); }
    .breadcrumb { padding: 1.25rem 0 0; font-family: var(--mono); font-size: 12px; color: var(--ink3); }
    .breadcrumb a { color: var(--ink3); }
    .breadcrumb a:hover { color: var(--accent-text); }
    .breadcrumb span { margin: 0 0.4rem; }
