  <style is:inline>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font); font-size: 16px; background: var(--bg); color: var(--ink); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    a { color: var(--accent-text); text-decoration: none; }
    a:hover { color: var(--accent); }
