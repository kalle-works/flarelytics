---
const features = [
  { title: 'No cookies', desc: 'No consent banners needed. GDPR, CCPA, and PECR compliant by architecture.' },
  { title: 'Under 1KB', desc: 'The tracking script is smaller than most cookie banners. Zero impact on page speed.' },
  { title: '100% Cloudflare', desc: 'Workers + Analytics Engine. No databases, no servers, no third-party services.' },
  { title: 'Real dashboard', desc: 'Traffic, referrers, countries, custom events, UTM tracking, conversion funnels.' },
  { title: 'Email reports', desc: 'Weekly digests with traffic trends, top pages, and anomaly alerts.' },
  { title: 'Custom events', desc: 'Track signups, purchases, clicks, or anything with flarelytics.track().' },
];

const comparisons = [
  { feature: 'Privacy-first', flarelytics: true, ga: false, plausible: true, counterscale: true },
  { feature: 'No cookies', flarelytics: true, ga: false, plausible: true, counterscale: true },
  { feature: 'Self-hosted', flarelytics: true, ga: false, plausible: true, counterscale: true },
  { feature: 'Runs on CF only', flarelytics: true, ga: false, plausible: false, counterscale: true },
  { feature: 'Custom events', flarelytics: true, ga: true, plausible: true, counterscale: false },
  { feature: 'Email reports', flarelytics: true, ga: true, plausible: true, counterscale: false },
  { feature: 'Dashboard', flarelytics: true, ga: true, plausible: true, counterscale: true },
  { feature: 'CSV export', flarelytics: true, ga: true, plausible: true, counterscale: false },
  { feature: 'Open source', flarelytics: true, ga: false, plausible: true, counterscale: true },
  { feature: 'Free tier', flarelytics: true, ga: true, plausible: false, counterscale: true },
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Flarelytics — Privacy-first analytics for Cloudflare</title>
  <meta name="description" content="Privacy-first web analytics that runs entirely on Cloudflare. No cookies, no external dependencies, 5-minute setup. Open source." />
  <link rel="canonical" href="https://flarelytics.dev" />
  <meta property="og:title" content="Flarelytics — Privacy-first analytics for Cloudflare" />
  <meta property="og:description" content="No cookies, no external dependencies, 5-minute setup. Open source." />
  <meta property="og:url" content="https://flarelytics.dev" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%231c1917'/%3E%3Crect x='7' y='12' width='4' height='12' rx='1' fill='%23fbbf24'/%3E%3Crect x='14' y='8' width='4' height='16' rx='1' fill='%23fbbf24'/%3E%3Crect x='21' y='16' width='4' height='8' rx='1' fill='%23fbbf24'/%3E%3C/svg%3E" />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@700,900&display=swap" rel="stylesheet" />
  <style is:inline>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: var(--font);
      font-size: 14.5px;
      background: var(--bg);
      color: var(--ink);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--accent-text); text-decoration: none; }
    a:hover { color: var(--accent); }
    .container { max-width: 880px; margin: 0 auto; padding: 0 1.5rem; }

    /* Nav */
    nav { padding: 1rem 0; border-bottom: 1px solid var(--border); }
    nav .inner { display: flex; align-items: center; justify-content: space-between; }
    .logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--mono);
      font-weight: 500;
      font-size: 15px;
      color: var(--ink);
      text-decoration: none;
    }
    .logo-icon { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; }
    .nav-links { display: flex; gap: 1.5rem; align-items: center; }
    .nav-links a { font-family: var(--mono); font-size: 12px; color: var(--ink2); }
    .nav-links a:hover { color: var(--ink); }

    .btn {
      display: inline-flex;
      align-items: center;
      min-height: 40px;
      padding: 0 1.25rem;
      border-radius: 6px;
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      transition: all 120ms;
      text-decoration: none;
    }
    .btn-primary { background: var(--ink); color: white; }
    .btn-primary:hover { background: #292524; color: white; }
    .btn-outline { border: 1px solid var(--border); color: var(--ink2); }
    .btn-outline:hover { border-color: var(--ink); color: var(--ink); }

    /* Hero */
    .hero { padding: 5rem 0 4rem; text-align: center; }
    .hero h1 {
      font-family: var(--display);
      font-size: 52px;
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -0.035em;
      max-width: 700px;
      margin: 0 auto;
    }
    .hero h1 span {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero p { margin: 1.25rem auto 0; max-width: 520px; font-size: 16px; color: var(--ink2); }
    .hero-badges { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin-top: 16px; }
    .badge {
      display: inline-block;
      font-family: var(--mono);
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      background: var(--accent-light);
      color: #92400e;
      padding: 4px 10px;
      border-radius: 20px;
    }
    .hero-actions { margin-top: 2rem; display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

    /* Code block */
    .code-block { margin: 3rem auto; max-width: 580px; background: #1c1917; border-radius: 6px; overflow: hidden; text-align: left; }
    .code-header { padding: 0.5rem 1rem; background: #292524; display: flex; align-items: center; gap: 0.5rem; }
    .code-dot { width: 10px; height: 10px; border-radius: 50%; }
    .code-body { padding: 1rem 1.25rem; font-family: var(--mono); font-size: 0.8125rem; line-height: 1.8; color: #d6d3d1; overflow-x: auto; }
    .code-comment { color: #78716c; }
    .code-string { color: #fbbf24; }
    .code-cmd { color: #d6d3d1; }

    /* Features */
    .features { padding: 4rem 0; }
    .features h2 { text-align: center; font-family: var(--display); font-size: 28px; font-weight: 700; margin-bottom: 2.5rem; }
    .feature-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .feature-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 16px 20px;
      transition: box-shadow 120ms, border-color 120ms;
    }
    .feature-card:hover { border-color: #d6d3d1; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .feature-title {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--accent-text);
      margin-bottom: 6px;
    }
    .feature-desc { font-size: 14.5px; color: var(--ink2); line-height: 1.5; }

    /* Comparison */
    .comparison { padding: 4rem 0; }
    .comparison h2 { text-align: center; font-family: var(--display); font-size: 28px; font-weight: 700; margin-bottom: 2.5rem; }
    .cmp-table { width: 100%; border-collapse: collapse; font-size: 14.5px; background: var(--card); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
    .cmp-table thead th {
      padding: 0.75rem 1rem;
      text-align: center;
      font-family: var(--mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--ink3);
      border-bottom: 2px solid var(--border);
    }
    .cmp-table thead th:first-child { text-align: left; }
    .cmp-table tbody td {
      padding: 0.625rem 1rem;
      text-align: center;
      border-bottom: 1px solid var(--border);
      color: var(--ink2);
      font-variant-numeric: tabular-nums;
    }
    .cmp-table tbody td:first-child { text-align: left; font-weight: 500; color: var(--ink); }
    .cmp-table tbody tr:last-child td { border-bottom: none; }
    .cmp-yes { color: var(--green); font-weight: 600; }
    .cmp-no { color: var(--red); }
    .cmp-highlight { background: var(--accent-light); }

    /* Privacy */
    .privacy { padding: 4rem 0; text-align: center; }
    .privacy h2 { font-family: var(--display); font-size: 28px; font-weight: 700; margin-bottom: 1rem; }
    .privacy p { max-width: 580px; margin: 0 auto; color: var(--ink2); font-size: 16px; }
    .privacy-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-width: 580px; margin: 2rem auto 0; text-align: left; }
    .privacy-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1rem 1.25rem;
      transition: box-shadow 120ms, border-color 120ms;
    }
    .privacy-item:hover { border-color: #d6d3d1; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .privacy-label {
      font-family: var(--mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--ink3);
      margin-bottom: 4px;
    }
    .privacy-value { font-family: var(--mono); font-weight: 600; font-size: 14.5px; }

    /* CTA */
    .cta { padding: 4rem 0; text-align: center; }
    .cta h2 { font-family: var(--display); font-size: 28px; font-weight: 700; margin-bottom: 0.5rem; }
    .cta p { color: var(--ink2); margin-bottom: 1.5rem; }

    /* Footer */
    footer { padding: 2rem 0; border-top: 1px solid var(--border); text-align: center; }
    footer p { font-family: var(--mono); font-size: 12px; color: var(--ink3); }
    footer a { color: var(--ink3); }
    footer a:hover { color: var(--accent-text); }

    @media (max-width: 640px) {
      .hero h1 { font-size: 36px; }
      .feature-grid { grid-template-columns: 1fr; }
      .privacy-grid { grid-template-columns: 1fr; }
      .cmp-table { font-size: 12px; }
      .cmp-table thead th, .cmp-table tbody td { padding: 0.5rem; }
    }
  </style>
</head>
<body style="--font:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;--display:'Satoshi',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;--mono:'SF Mono','Fira Code','Menlo',monospace;--ink:#1c1917;--ink2:#57534e;--ink3:#78716c;--bg:#fafaf9;--card:#ffffff;--border:#e7e5e4;--accent:#d97706;--accent2:#b45309;--accent-text:#b45309;--accent-light:#fffbeb;--green:#16a34a;--red:#dc2626;">
  <!-- Nav -->
  <nav>
    <div class="container inner">
      <a href="/" class="logo">
        <div class="logo-icon">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
            <rect width="32" height="32" rx="6" fill="#1c1917"/>
            <rect x="7" y="12" width="4" height="12" rx="1" fill="#fbbf24"/>
            <rect x="14" y="8" width="4" height="16" rx="1" fill="#fbbf24"/>
            <rect x="21" y="16" width="4" height="8" rx="1" fill="#fbbf24"/>
          </svg>
        </div>
        flarelytics
      </a>
      <div class="nav-links">
        <a href="https://github.com/kalle-works/flarelytics">GitHub</a>
        <a href="https://github.com/kalle-works/flarelytics/blob/main/README.md">Docs</a>
        <a href="https://github.com/kalle-works/flarelytics" class="btn btn-primary">Get Started</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero container">
    <h1>Privacy-first analytics for <span>Cloudflare</span></h1>
    <p>No cookies. No external dependencies. Runs entirely on Cloudflare Workers. Deploy in 5 minutes. Open source.</p>
    <div class="hero-badges">
      <span class="badge">MIT Licensed</span>
      <span class="badge">Open Source</span>
      <span class="badge">&lt;1KB Script</span>
    </div>
    <div class="hero-actions">
      <a href="https://github.com/kalle-works/flarelytics" class="btn btn-primary">View on GitHub</a>
      <a href="#quickstart" class="btn btn-outline">Quick Start</a>
    </div>
  </section>

  <!-- Quick Start -->
  <section id="quickstart" class="container">
    <div class="code-block">
      <div class="code-header">
        <div class="code-dot" style="background:#dc2626;"></div>
        <div class="code-dot" style="background:#d97706;"></div>
        <div class="code-dot" style="background:#16a34a;"></div>
      </div>
      <div class="code-body">
        <div><span class="code-comment"># Clone and deploy</span></div>
        <div><span class="code-cmd">git clone https://github.com/kalle-works/flarelytics</span></div>
        <div><span class="code-cmd">cd flarelytics/packages/worker</span></div>
        <div><span class="code-cmd">npx wrangler deploy</span></div>
        <div>&nbsp;</div>
        <div><span class="code-comment"># Add to your site</span></div>
        <div><span class="code-string">&lt;script defer src="https://your-worker.workers.dev/tracker.js"&gt;&lt;/script&gt;</span></div>
        <div>&nbsp;</div>
        <div><span class="code-comment"># Track custom events</span></div>
        <div><span class="code-cmd">flarelytics.track(<span class="code-string">'signup'</span>, {"{"} props: {"{"} plan: <span class="code-string">'pro'</span> {"}"} {"}"})</span></div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features container">
    <h2>Everything you need, nothing you don't</h2>
    <div class="feature-grid">
      {features.map((f) => (
        <div class="feature-card">
          <div class="feature-title">{f.title}</div>
          <div class="feature-desc">{f.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Privacy -->
  <section class="privacy container">
    <h2>Privacy by architecture, not policy</h2>
    <p>Flarelytics doesn't need a privacy policy because it doesn't collect personal data. No cookies, no fingerprinting, no IP addresses stored.</p>
    <div class="privacy-grid">
      <div class="privacy-item">
        <div class="privacy-label">Cookies</div>
        <div class="privacy-value" style="color:var(--green);">None</div>
      </div>
      <div class="privacy-item">
        <div class="privacy-label">IP addresses</div>
        <div class="privacy-value" style="color:var(--green);">Never stored</div>
      </div>
      <div class="privacy-item">
        <div class="privacy-label">Visitor tracking</div>
        <div class="privacy-value">Daily hash, resets at midnight</div>
      </div>
      <div class="privacy-item">
        <div class="privacy-label">GDPR compliant</div>
        <div class="privacy-value" style="color:var(--green);">By default</div>
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="comparison container">
    <h2>How Flarelytics compares</h2>
    <div style="overflow-x:auto;">
      <table class="cmp-table">
        <thead>
          <tr>
            <th>Feature</th>
            <th class="cmp-highlight">Flarelytics</th>
            <th>Google Analytics</th>
            <th>Plausible</th>
            <th>Counterscale</th>
          </tr>
        </thead>
        <tbody>
          {comparisons.map((row) => {
            const fl = row.flarelytics;
            const ga = row.ga;
            const pl = row.plausible;
            const cs = row.counterscale;
            return (
              <tr>
                <td>{row.feature}</td>
                <td class="cmp-highlight">{fl && <span class="cmp-yes">Yes</span>}{!fl && <span class="cmp-no">No</span>}</td>
                <td>{ga && <span class="cmp-yes">Yes</span>}{!ga && <span class="cmp-no">No</span>}</td>
                <td>{pl && <span class="cmp-yes">Yes</span>}{!pl && <span class="cmp-no">No</span>}</td>
                <td>{cs && <span class="cmp-yes">Yes</span>}{!cs && <span class="cmp-no">No</span>}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta container">
    <h2>Deploy analytics in 5 minutes</h2>
    <p>One git clone, one wrangler deploy, one script tag. That's it.</p>
    <a href="https://github.com/kalle-works/flarelytics" class="btn btn-primary" style="font-size:14px;padding:0 2rem;min-height:48px;">Get Started on GitHub</a>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container">
      <p>
        Flarelytics is open source (MIT) &middot;
        <a href="https://github.com/kalle-works/flarelytics">GitHub</a> &middot;
        Built by <a href="https://kalle.works">kalle.works</a>
      </p>
    </div>
  </footer>
</body>
</html>
