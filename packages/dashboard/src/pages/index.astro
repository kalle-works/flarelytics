  function loadFunnelByEvent(eventName) {
    var funnelEl = document.getElementById('funnel');
    funnelEl.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--ink-muted);font-family:var(--mono);font-size:12px;">Loading...</div>';

    if (!eventName) {
      query('conversion-funnel').then(function(d) {
        renderFunnel(rows(d));
      });
      return;
    }

    var url = WORKER + '/query?q=funnel-by-event&period=' + period + '&site=' + encodeURIComponent(site) + '&event_name=' + encodeURIComponent(eventName);
    fetch(url, { headers: { 'X-API-Key': apiKey } })
      .then(function(r) { return r.json(); })
      .then(function(d) { renderFunnel(rows(d)); })
      .catch(function() { renderFunnel([]); });
  }

  function loadAll() {
    // Skeletons
    document.querySelectorAll('.kpi-value').forEach(function(el) { el.innerHTML = skel(70); });
    document.querySelectorAll('.kpi-wow').forEach(function(el) { el.textContent = ''; });
    document.getElementById('chart-traffic').innerHTML = '<div style="display:flex;height:100%;align-items:center;justify-content:center;color:var(--ink-muted);font-family:var(--mono);font-size:12px;">Loading...</div>';

    var qs = ['daily-views','daily-unique-visitors','top-pages-visitors','referrers','countries','custom-events','outbound-links','utm-campaigns','conversion-funnel','page-timing','devices','browsers','top-pages-stories','total-sessions','bot-hits','bot-hits-total','bot-pages','bot-daily','bot-countries'];

    var mainPromise = Promise.all(qs.map(function(q) {
      return query(q).then(function(d) { return { q: q, d: d }; });
    }));

    var wowPromise = Promise.all([
      queryWow('daily-views').then(function(d) { return { q: 'daily-views', d: d }; }),
      queryWow('daily-unique-visitors').then(function(d) { return { q: 'daily-unique-visitors', d: d }; })
    ]);

    mainPromise.then(function(results) {
      var m = {};
      results.forEach(function(r) { m[r.q] = r.d; });

      // KPIs
      var dv = rows(m['daily-views']);
      var duv = rows(m['daily-unique-visitors']);
      var funnel = rows(m['conversion-funnel']);
      var sessionsData = rows(m['total-sessions']);
      var totalViews = sum(dv, 'views');
      var totalVisitors = sum(duv, 'unique_visitors');
      var totalSessions = sessionsData.length ? (parseFloat(sessionsData[0].sessions) || 0) : 0;

      // Conversion rate: real custom events (exclude scroll_depth, timing) / pageviews
      var allEventRows = rows(m['custom-events']);
      var realEventCount = allEventRows
        .filter(function(r) { return !INTERNAL_EVENTS[r.event]; })
        .reduce(function(acc, r) { return acc + (parseFloat(r.count) || 0); }, 0);
      var convRate = totalViews > 0
        ? (realEventCount / totalViews * 100).toFixed(1) + '%'
        : '-';

      document.querySelector('[data-kpi="views"] .kpi-value').textContent = num(totalViews);
      document.querySelector('[data-kpi="visitors"] .kpi-value').textContent = num(totalVisitors);
      document.querySelector('[data-kpi="sessions"] .kpi-value').textContent = num(totalSessions);
      document.querySelector('[data-kpi="convrate"] .kpi-value').textContent = convRate;

      // Traffic chart
      renderChart(dv);

      // Top pages with share column and visitors
      tablePages['table-pages'] = 0;
      fillTopPages(m['top-pages-visitors'], m['custom-events'], 0);

      // Other tables
      tablePages['table-referrers'] = 0;
      fillTable('table-referrers', m['referrers'], [{ key: 'referrer', favicon: true }, { key: 'visits', align: 'right', fmt: 'num' }], true);
      tablePages['table-countries'] = 0;
      fillTable('table-countries', m['countries'], [{ key: 'country' }, { key: 'views', align: 'right', fmt: 'num' }], true);
      renderDeviceBadges(m['devices']);
      tablePages['table-events'] = 0;
      var filteredEvents = { data: rows(m['custom-events']).filter(function(r) { return !INTERNAL_EVENTS[r.event]; }) };
      fillTable('table-events', filteredEvents, [{ key: 'event' }, { key: 'properties', fmt: 'props' }, { key: 'count', align: 'right', fmt: 'num' }], true);
      fillTable('table-outbound', m['outbound-links'], [{ key: 'destination' }, { key: 'clicks', align: 'right', fmt: 'num' }]);
      fillTable('table-utm', m['utm-campaigns'], [{ key: 'utm_source' }, { key: 'utm_medium' }, { key: 'utm_campaign' }, { key: 'visits', align: 'right', fmt: 'num' }]);

      // Time on page
      fillTimingTable(m['page-timing']);

      // Browsers
      fillTable('table-browsers', m['browsers'], [
        { key: 'browser' },
        { key: 'views', align: 'right', fmt: 'num' }
      ]);

      // Top Articles (only shown if data exists)
      fillTopStories(m['top-pages-stories']);

      // Bot Traffic
      renderBotTraffic(m['bot-hits'], m['bot-hits-total'], m['bot-pages'], m['bot-daily'], m['bot-countries'], totalViews);

      // Funnel
      var currentFunnelEvent = document.getElementById('funnel-event-select').value;
      renderFunnel(funnel);

      // Populate funnel event selector
      populateFunnelEventSelect(m['custom-events']);
      // Restore selection if it existed
      if (currentFunnelEvent) {
        var sel = document.getElementById('funnel-event-select');
        sel.value = currentFunnelEvent;
      }
    });

    // WoW badges — resolve independently
    wowPromise.then(function(results) {
      var wm = {};
      results.forEach(function(r) { wm[r.q] = r.d; });

      var dvWow = rows(wm['daily-views']);
      var duvWow = rows(wm['daily-unique-visitors']);

      var viewsPct = computeWow(dvWow, 'views');
      var visitorsPct = computeWow(duvWow, 'unique_visitors');

      renderWow('[data-wow="views"]', viewsPct);
      renderWow('[data-wow="visitors"]', visitorsPct);
    });
  }

  var BOT_CATEGORIES = [
    { label: 'Hakukoneet', patterns: ['googlebot', 'bingbot', 'yandex', 'baidu', 'slurp'] },
    { label: 'AI-crawlerit', patterns: ['gptbot', 'claudebot', 'bytespider'] },
    { label: 'SEO-ty\u00f6kalut', patterns: ['ahrefs', 'semrush', 'moz.com', 'dotbot'] },
    { label: 'Some', patterns: ['facebookexternalhit', 'twitterbot', 'linkedinbot', 'whatsapp', 'telegrambot'] },
    { label: 'Monitorointi', patterns: ['lighthouse', 'pagespeed', 'gtmetrix', 'pingdom', 'uptimerobot'] },
  ];

  function categorizeBot(ua) {
    var lower = (ua || '').toLowerCase();
    for (var i = 0; i < BOT_CATEGORIES.length; i++) {
      for (var j = 0; j < BOT_CATEGORIES[i].patterns.length; j++) {
        if (lower.includes(BOT_CATEGORIES[i].patterns[j])) return BOT_CATEGORIES[i].label;
      }
    }
    return 'Muu';
  }

  function renderBotTraffic(botHits, botTotal, botPages, botDaily, botCountries, totalViews) {
    var bots = rows(botHits);
    var totalBotHits = botTotal && rows(botTotal).length ? (parseFloat(rows(botTotal)[0].total_bot_hits) || 0) : 0;
    document.getElementById('bot-total').textContent = num(totalBotHits);
    var pctEl = document.getElementById('bot-pct');
    if (totalViews > 0 && totalBotHits > 0) {
      pctEl.textContent = '(' + (totalBotHits / (totalViews + totalBotHits) * 100).toFixed(1) + '% of all traffic)';
    } else {
      pctEl.textContent = '';
    }

    // Bot daily trend chart
    renderBotChart(botDaily);

    // Bot categories (computed from bot-hits UA data)
    renderBotCategories(bots, totalBotHits);

    // Tables
    tablePages['table-bot-pages'] = 0;
    fillTable('table-bot-pages', botPages, [{ key: 'path' }, { key: 'hits', align: 'right', fmt: 'num' }], true);
    tablePages['table-bot-countries'] = 0;
    fillTable('table-bot-countries', botCountries, [{ key: 'country' }, { key: 'hits', align: 'right', fmt: 'num' }], true);
    tablePages['table-bots'] = 0;
    fillTable('table-bots', botHits, [{ key: 'user_agent' }, { key: 'hits', align: 'right', fmt: 'num' }], true);
  }

