  function renderBotCategories(bots, totalBotHits) {
    var el = document.getElementById('bot-categories');
    if (!bots.length || !totalBotHits) { el.innerHTML = '<div style="font-family:var(--mono);font-size:12px;color:var(--ink-muted);">No data</div>'; return; }

    // Aggregate hits per category
    var cats = {};
    bots.forEach(function(b) {
      var cat = categorizeBot(b.user_agent);
      cats[cat] = (cats[cat] || 0) + (parseFloat(b.hits) || 0);
    });

    // Sort by hits descending
    var sorted = Object.keys(cats).map(function(k) { return { label: k, hits: cats[k] }; });
    sorted.sort(function(a, b) { return b.hits - a.hits; });

    var maxHits = sorted[0] ? sorted[0].hits : 1;
    var html = '';
    sorted.forEach(function(cat) {
      var pct = totalBotHits > 0 ? (cat.hits / totalBotHits * 100).toFixed(0) : 0;
      var barWidth = (cat.hits / maxHits * 100).toFixed(1);
      html += '<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:6px;">';
      html += '<span style="font-family:var(--mono);font-size:12px;color:var(--ink-secondary);min-width:100px;">' + esc(cat.label) + '</span>';
      html += '<div style="flex:1;height:16px;background:var(--border-light);border-radius:2px;overflow:hidden;">';
      html += '<div style="height:100%;width:' + barWidth + '%;background:var(--data-muted);border-radius:2px;"></div>';
      html += '</div>';
      html += '<span style="font-family:var(--mono);font-size:11px;color:var(--ink-muted);min-width:60px;text-align:right;">' + num(cat.hits) + ' (' + pct + '%)</span>';
      html += '</div>';
    });
    el.innerHTML = html;
  }

