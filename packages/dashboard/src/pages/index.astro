  window.openDrilldown = function(pagePath) {
    var overlay = document.getElementById('drilldown-overlay');
    overlay.style.display = '';
    document.getElementById('drilldown-title').textContent = pagePath;

    // Reset
    document.getElementById('dd-views').textContent = '-';
    document.getElementById('dd-visitors').textContent = '-';
    document.getElementById('dd-time').textContent = '-';
    document.getElementById('dd-read100').textContent = '-';
    destroyChart('dd-chart');
    document.getElementById('dd-chart').innerHTML = '<div style="display:flex;height:100%;align-items:center;justify-content:center;color:var(--ink-muted);font-family:var(--mono);font-size:12px;">Loading...</div>';
    document.getElementById('dd-scroll-depth').innerHTML = '';
    document.querySelector('#table-dd-referrers tbody').innerHTML = '';
    document.querySelector('#table-dd-countries tbody').innerHTML = '';
    document.querySelector('#table-dd-utm tbody').innerHTML = '';

    Promise.all([
      queryPage('page-views-over-time', pagePath),
      queryPage('timing-by-page', pagePath),
      queryPage('scroll-depth-for-page', pagePath),
      queryPage('referrers-by-page', pagePath),
      queryPage('countries-by-page', pagePath),
      queryPage('utm-by-page', pagePath),
    ]).then(function(results) {
      var viewsData = rows(results[0]);
      var timingData = rows(results[1]);
      var scrollData = rows(results[2]);
      var refData = results[3];
      var countryData = results[4];
      var utmData = results[5];

      // KPIs
      var totalViews = sum(viewsData, 'views');
      var totalVisitors = sum(viewsData, 'visitors');
      document.getElementById('dd-views').textContent = num(totalViews);
      document.getElementById('dd-visitors').textContent = num(totalVisitors);

      if (timingData.length && timingData[0].avg_seconds) {
        var secs = Math.round(parseFloat(timingData[0].avg_seconds));
        var mins = Math.floor(secs / 60);
        document.getElementById('dd-time').textContent = mins > 0 ? mins + 'm ' + (secs % 60) + 's' : secs + 's';
      }

      // Read 100%
      var read100 = 0;
      scrollData.forEach(function(r) { if (String(r.depth) === '100') read100 = parseFloat(r.count) || 0; });
      document.getElementById('dd-read100').textContent = read100 > 0 ? num(read100) : '-';

      // Chart
      renderDrilldownChart(viewsData);

      // Scroll depth funnel
      renderDrilldownScroll(scrollData);

      // Tables
      fillTable('table-dd-referrers', refData, [{ key: 'referrer', favicon: true }, { key: 'visits', align: 'right', fmt: 'num' }]);
      fillTable('table-dd-countries', countryData, [{ key: 'country' }, { key: 'views', align: 'right', fmt: 'num' }]);
      fillTable('table-dd-utm', utmData, [{ key: 'utm_source' }, { key: 'utm_medium' }, { key: 'utm_campaign' }, { key: 'visits', align: 'right', fmt: 'num' }]);
    });
  };

