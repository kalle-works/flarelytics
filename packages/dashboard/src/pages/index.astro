  function renderDrilldownScroll(scrollData) {
    var el = document.getElementById('dd-scroll-depth');
    if (!scrollData.length) { el.innerHTML = '<div style="font-family:var(--mono);font-size:12px;color:var(--ink-muted);">No scroll data</div>'; return; }

    var depthMap = {};
    scrollData.forEach(function(r) { depthMap[String(r.depth)] = parseFloat(r.count) || 0; });
    var depths = ['25', '50', '75', '100'];
    var maxCount = Math.max.apply(null, depths.map(function(d) { return depthMap[d] || 0; }));
    if (maxCount === 0) maxCount = 1;

    var html = '';
    depths.forEach(function(d) {
      var count = depthMap[d] || 0;
      var barW = (count / maxCount * 100).toFixed(1);
      html += '<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:6px;">';
      html += '<span style="font-family:var(--mono);font-size:12px;color:var(--ink-secondary);min-width:40px;text-align:right;">' + d + '%</span>';
      html += '<div style="flex:1;height:16px;background:var(--border-light);border-radius:2px;overflow:hidden;">';
      html += '<div style="height:100%;width:' + barW + '%;background:var(--accent);border-radius:2px;transition:width 300ms;"></div>';
      html += '</div>';
      html += '<span style="font-family:var(--mono);font-size:11px;color:var(--ink-muted);min-width:40px;text-align:right;">' + num(count) + '</span>';
      html += '</div>';
    });
    el.innerHTML = html;
  }

