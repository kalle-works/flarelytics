    return fetch(WORKER + '/query?q=' + q + '&period=' + period + '&site=' + encodeURIComponent(site) + '&page=' + encodeURIComponent(pagePath), { headers: { 'X-API-Key': apiKey } })
      .then(function(r) { return r.json(); })
