---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Flarelytics Dashboard">
  <!-- Auth gate -->
  <div id="auth-gate" style="max-width:400px;margin:5rem auto;text-align:center;">
    <svg width="40" height="40" viewBox="0 0 32 32" fill="none" style="margin:0 auto 1rem;">
      <rect width="32" height="32" rx="6" fill="#1c1917"/>
      <rect x="7" y="12" width="4" height="12" rx="1" fill="#fbbf24"/>
      <rect x="14" y="8" width="4" height="16" rx="1" fill="#fbbf24"/>
      <rect x="21" y="16" width="4" height="8" rx="1" fill="#fbbf24"/>
    </svg>
    <h1 style="font-family:var(--mono);font-size:1.25rem;font-weight:600;margin-bottom:0.5rem;">flarelytics</h1>
    <p style="font-size:0.875rem;color:var(--ink-muted);margin-bottom:1.5rem;">Enter your API key to view analytics.</p>
    <form id="auth-form" style="display:flex;flex-direction:column;gap:0.75rem;">
      <input
        id="api-key"
        type="password"
        placeholder="API key"
        required
        style="min-height:44px;border-radius:var(--radius-lg);border:1px solid var(--border);background:var(--surface-raised);padding:0 1rem;font-family:var(--mono);font-size:0.8125rem;color:var(--ink);outline:none;"
      />
      <input
        id="worker-url"
        type="url"
        placeholder="Worker URL (e.g. https://analytics.yoursite.com)"
        required
        style="min-height:44px;border-radius:var(--radius-lg);border:1px solid var(--border);background:var(--surface-raised);padding:0 1rem;font-family:var(--mono);font-size:0.8125rem;color:var(--ink);outline:none;"
      />
      <input
        id="site-hostname"
        type="text"
        placeholder="Site hostname (e.g. yoursite.com)"
        required
        style="min-height:44px;border-radius:var(--radius-lg);border:1px solid var(--border);background:var(--surface-raised);padding:0 1rem;font-family:var(--mono);font-size:0.8125rem;color:var(--ink);outline:none;"
      />
      <input
        id="site-label"
        type="text"
        placeholder="Label (optional, e.g. My Blog)"
        style="min-height:44px;border-radius:var(--radius-lg);border:1px solid var(--border);background:var(--surface-raised);padding:0 1rem;font-family:var(--mono);font-size:0.8125rem;color:var(--ink);outline:none;"
      />
      <button
        type="submit"
        style="min-height:44px;border-radius:var(--radius-lg);background:#1c1917;color:white;font-family:var(--mono);font-size:0.8125rem;font-weight:600;border:none;cursor:pointer;transition:background 120ms;"
        onmouseover="this.style.background='#292524'"
        onmouseout="this.style.background='#1c1917'"
      >
        View Dashboard
      </button>
      <p id="auth-error" style="display:none;font-size:0.875rem;color:var(--red);">Could not connect. Check your API key and worker URL.</p>
    </form>
  </div>

  <!-- Dashboard -->
  <div id="dashboard" style="display:none;">
    <!-- Header -->
    <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1.5rem;">
      <div style="display:flex;align-items:center;gap:0.75rem;">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
          <rect width="32" height="32" rx="6" fill="#1c1917"/>
          <rect x="7" y="12" width="4" height="12" rx="1" fill="#fbbf24"/>
          <rect x="14" y="8" width="4" height="16" rx="1" fill="#fbbf24"/>
          <rect x="21" y="16" width="4" height="8" rx="1" fill="#fbbf24"/>
        </svg>
        <h1 style="font-family:var(--mono);font-size:1rem;font-weight:500;">flarelytics</h1>
        <select id="site-switcher" style="display:none;font-family:var(--mono);font-size:0.8125rem;border:1px solid var(--border);background:var(--surface-raised);border-radius:var(--radius-lg);padding:0.25rem 0.5rem;color:var(--ink);cursor:pointer;"></select>
      </div>
      <div style="display:flex;align-items:center;gap:0.5rem;">
        <div id="period-group" style="display:flex;border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;">
          <button class="period-btn active" data-period="7d">7d</button>
          <button class="period-btn" data-period="30d">30d</button>
          <button class="period-btn" data-period="90d">90d</button>
        </div>
        <button id="live-btn" class="icon-btn" title="Live view" style="font-size:0.75rem;font-family:var(--mono);font-weight:600;gap:6px;padding:0 12px;min-width:auto;">
          <span id="live-dot" style="width:8px;height:8px;border-radius:50%;background:#dc2626;display:inline-block;"></span>
          LIVE
        </button>
        <button id="refresh-btn" class="icon-btn" title="Refresh">&#x21BB;</button>
        <button id="export-btn" class="icon-btn" title="Export CSV">&#x2193;</button>
      </div>
    </div>

    <!-- KPI Cards -->
    <div id="kpi-cards" style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;margin-bottom:2rem;">
      <div class="card kpi" data-kpi="views">
        <span class="kpi-label">Pageviews</span>
        <span class="kpi-value">-</span>
        <span class="kpi-wow" data-wow="views"></span>
      </div>
      <div class="card kpi" data-kpi="visitors">
        <span class="kpi-label">Unique Visitors</span>
        <span class="kpi-value">-</span>
        <span class="kpi-wow" data-wow="visitors"></span>
      </div>
      <div class="card kpi" data-kpi="sessions">
        <span class="kpi-label">Sessions</span>
        <span class="kpi-value">-</span>
      </div>
      <div class="card kpi" data-kpi="convrate">
        <span class="kpi-label">Conv. Rate</span>
        <span class="kpi-value">-</span>
      </div>
    </div>

    <!-- Live Panel -->
    <div id="live-panel" style="display:none;margin-bottom:1.5rem;">
      <div class="card" style="border-color:var(--accent);position:relative;overflow:hidden;">
        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
          <span id="live-pulse" style="width:8px;height:8px;border-radius:50%;background:#dc2626;display:inline-block;"></span>
          <span style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-muted);">Live &mdash; last 30 min</span>
          <span id="live-updated" style="font-family:var(--mono);font-size:10px;color:var(--ink-muted);margin-left:auto;"></span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;" class="live-kpi-grid">
          <div>
            <div style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);margin-bottom:4px;">Visitors</div>
            <div id="live-visitors" style="font-family:var(--mono);font-size:2rem;font-weight:700;font-variant-numeric:tabular-nums;">-</div>
          </div>
          <div>
            <div style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);margin-bottom:4px;">Pageviews</div>
            <div id="live-pageviews" style="font-family:var(--mono);font-size:2rem;font-weight:700;font-variant-numeric:tabular-nums;">-</div>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.5rem;" class="live-bottom-grid">
          <div>
            <div style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);margin-bottom:0.5rem;">Active Pages</div>
            <div id="live-pages-list" style="font-size:13px;color:var(--ink-secondary);"></div>
          </div>
          <div>
            <div style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);margin-bottom:0.5rem;">Mistä tulevat</div>
            <div id="live-referrers-list" style="font-size:13px;color:var(--ink-secondary);"></div>
          </div>
          <div>
            <div style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);margin-bottom:0.5rem;">Last 24 Hours</div>
            <div id="live-chart" style="height:80px;"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Traffic Chart -->
    <div class="section">
      <h2 class="section-title">Traffic</h2>
      <div class="card"><div id="chart-traffic" style="height:240px;width:100%;"></div></div>
    </div>

    <!-- Two-column: Top Pages + Referrers -->
    <div style="display:grid;grid-template-columns:1fr;gap:1.5rem;margin-bottom:1.5rem;" class="two-col">
      <div class="section">
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <h2 class="section-title">Top Pages</h2>
          <button class="csv-btn" data-table="table-pages">CSV</button>
        </div>
        <div class="card table-wrap">
          <table class="tbl" id="table-pages">
            <thead><tr><th style="text-align:left;">Path</th><th style="text-align:right;">Views</th><th style="text-align:right;">Visitors</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
      <div class="section">
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <h2 class="section-title">Referrers</h2>
          <button class="csv-btn" data-table="table-referrers">CSV</button>
        </div>
        <div class="card table-wrap">
          <table class="tbl" id="table-referrers">
            <thead><tr><th style="text-align:left;">Source</th><th style="text-align:right;">Visits</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Top Articles (hidden if no /a/ paths) -->
    <div id="section-top-stories" class="section" style="display:none;">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <h2 class="section-title">Top Articles</h2>
      </div>
      <div class="card table-wrap">
        <table class="tbl" id="table-stories">
          <thead><tr><th style="text-align:left;">Article</th><th style="text-align:right;">Views</th><th style="text-align:right;">Visitors</th><th style="width:80px;"></th></tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <!-- Two-column: Countries + Custom Events -->
    <div style="display:grid;grid-template-columns:1fr;gap:1.5rem;margin-bottom:1.5rem;" class="two-col">
      <div class="section">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;">
          <div style="display:flex;gap:1rem;">
            <h2 class="section-title">Countries</h2>
            <button class="csv-btn" data-table="table-countries">CSV</button>
          </div>
          <div style="display:flex;gap:0.5rem;align-items:center;">
            <span style="font-family:var(--mono);font-size:0.75rem;color:var(--ink-muted);">Laitteet</span>
            <span id="device-badges" style="display:flex;gap:0.375rem;"></span>
          </div>
        </div>
        <div class="card table-wrap">
          <table class="tbl" id="table-countries">
            <thead><tr><th style="text-align:left;">Country</th><th style="text-align:right;">Views</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
      <div class="section">
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <h2 class="section-title">Custom Events</h2>
          <button class="csv-btn" data-table="table-events">CSV</button>
        </div>
        <div class="card table-wrap">
          <table class="tbl" id="table-events">
            <thead><tr><th style="text-align:left;">Event</th><th style="text-align:left;">Properties</th><th style="text-align:right;">Count</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- UTM + Outbound -->
    <div style="display:grid;grid-template-columns:1fr;gap:1.5rem;margin-bottom:1.5rem;" class="two-col">
      <div class="section">
        <h2 class="section-title">UTM Campaigns</h2>
        <div class="card table-wrap">
          <table class="tbl" id="table-utm">
            <thead><tr><th style="text-align:left;">Source</th><th style="text-align:left;">Medium</th><th style="text-align:left;">Campaign</th><th style="text-align:right;">Visits</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
      <div class="section">
        <h2 class="section-title">Outbound Links</h2>
        <div class="card table-wrap">
          <table class="tbl" id="table-outbound">
            <thead><tr><th style="text-align:left;">Destination</th><th style="text-align:right;">Clicks</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Time on Page -->
    <div class="section" style="margin-bottom:1.5rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <h2 class="section-title">Aika sivulla</h2>
        <button class="csv-btn" data-table="table-timing">CSV</button>
      </div>
      <div class="card table-wrap">
        <table class="tbl" id="table-timing">
          <thead><tr><th style="text-align:left;">Path</th><th style="text-align:right;">Keskim. aika</th><th style="text-align:right;">Mittauksia</th></tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <!-- Selaimet -->
    <div class="section" style="margin-bottom:1.5rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <h2 class="section-title">Selaimet</h2>
        <button class="csv-btn" data-table="table-browsers">CSV</button>
      </div>
      <div class="card table-wrap">
        <table class="tbl" id="table-browsers">
          <thead><tr><th style="text-align:left;">Selain</th><th style="text-align:right;">Views</th></tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <!-- Funnel -->
    <div class="section">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
        <h2 class="section-title" style="margin-bottom:0;">Conversion Funnel</h2>
        <select id="funnel-event-select" style="font-family:var(--mono);font-size:0.8125rem;border:1px solid var(--border);background:var(--surface-raised);border-radius:var(--radius-lg);padding:0.25rem 0.5rem;color:var(--ink);cursor:pointer;">
          <option value="">Kaikki eventit</option>
        </select>
      </div>
      <div class="card" id="funnel"></div>
    </div>

    <!-- Bot Traffic -->
    <div class="section" style="margin-top:1.5rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <h2 class="section-title">Bot Traffic</h2>
      </div>
      <div style="display:flex;align-items:baseline;gap:0.75rem;margin-bottom:1rem;">
        <span id="bot-total" style="font-family:var(--mono);font-size:1.5rem;font-weight:700;">-</span>
        <span style="font-family:var(--mono);font-size:0.75rem;color:var(--ink-muted);">blocked requests</span>
        <span id="bot-pct" style="font-family:var(--mono);font-size:0.75rem;color:var(--ink-muted);"></span>
      </div>

      <!-- Bot trend chart -->
      <div class="card" style="margin-bottom:1rem;"><div id="chart-bot-daily" style="height:180px;width:100%;"></div></div>

      <!-- Bot categories -->
      <div class="card" style="margin-bottom:1rem;padding:1rem;">
        <div style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);margin-bottom:0.75rem;">Categories</div>
        <div id="bot-categories"></div>
      </div>

      <!-- Bot tables: pages + countries + user-agents -->
      <div style="display:grid;grid-template-columns:1fr;gap:1rem;" class="two-col">
        <div>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
            <span style="font-family:var(--mono);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);">Top Pages</span>
            <button class="csv-btn" data-table="table-bot-pages">CSV</button>
          </div>
          <div class="card table-wrap">
            <table class="tbl" id="table-bot-pages">
              <thead><tr><th style="text-align:left;">Path</th><th style="text-align:right;">Hits</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
        <div>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
            <span style="font-family:var(--mono);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);">Countries</span>
            <button class="csv-btn" data-table="table-bot-countries">CSV</button>
          </div>
          <div class="card table-wrap">
            <table class="tbl" id="table-bot-countries">
              <thead><tr><th style="text-align:left;">Country</th><th style="text-align:right;">Hits</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
        <div>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
            <span style="font-family:var(--mono);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);">Top User-Agents</span>
            <button class="csv-btn" data-table="table-bots">CSV</button>
          </div>
          <div class="card table-wrap">
            <table class="tbl" id="table-bots">
              <thead><tr><th style="text-align:left;">User-Agent</th><th style="text-align:right;">Hits</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Article Drill-down Panel -->
    <div id="drilldown-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;overflow-y:auto;" onclick="if(event.target===this)closeDrilldown()">
      <div style="max-width:720px;margin:3rem auto;background:var(--surface-raised);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.5rem;position:relative;">
        <button onclick="closeDrilldown()" style="position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.25rem;cursor:pointer;color:var(--ink-muted);">&#x2715;</button>
        <h2 id="drilldown-title" style="font-family:var(--mono);font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;padding-right:2rem;word-break:break-all;"></h2>

        <!-- Drilldown KPIs -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-bottom:1.5rem;">
          <div class="card kpi" style="padding:0.75rem;">
            <span class="kpi-label">Views</span>
            <span class="kpi-value" id="dd-views">-</span>
          </div>
          <div class="card kpi" style="padding:0.75rem;">
            <span class="kpi-label">Visitors</span>
            <span class="kpi-value" id="dd-visitors">-</span>
          </div>
          <div class="card kpi" style="padding:0.75rem;">
            <span class="kpi-label">Avg. Time</span>
            <span class="kpi-value" id="dd-time">-</span>
          </div>
          <div class="card kpi" style="padding:0.75rem;">
            <span class="kpi-label">Read 100%</span>
            <span class="kpi-value" id="dd-read100">-</span>
          </div>
        </div>

        <!-- Drilldown chart -->
        <div class="card" style="margin-bottom:1rem;"><div id="dd-chart" style="height:160px;width:100%;"></div></div>

        <!-- Scroll depth funnel -->
        <div class="card" style="margin-bottom:1rem;padding:1rem;">
          <div style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);margin-bottom:0.75rem;">Scroll Depth</div>
          <div id="dd-scroll-depth"></div>
        </div>

        <!-- Referrers + Countries + UTM -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
          <div>
            <div style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);margin-bottom:0.5rem;">Referrers</div>
            <div class="card table-wrap">
              <table class="tbl" id="table-dd-referrers">
                <thead><tr><th style="text-align:left;">Source</th><th style="text-align:right;">Visits</th></tr></thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
          <div>
            <div style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);margin-bottom:0.5rem;">Countries</div>
            <div class="card table-wrap">
              <table class="tbl" id="table-dd-countries">
                <thead><tr><th style="text-align:left;">Country</th><th style="text-align:right;">Views</th></tr></thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
        <div>
          <div style="font-family:var(--mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-muted);margin-bottom:0.5rem;">UTM Campaigns</div>
          <div class="card table-wrap">
            <table class="tbl" id="table-dd-utm">
              <thead><tr><th style="text-align:left;">Source</th><th style="text-align:left;">Medium</th><th style="text-align:left;">Campaign</th><th style="text-align:right;">Visits</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import Chart from 'chart.js/auto';
  // Expose Chart globally for the inline dashboard script. Module scripts
  // are deferred (run after HTML parsing), while the inline script fires
  // fetch calls during parsing. The 'chartjs-ready' event ensures render
  // functions wait for Chart.js even when API responses beat the module.
  (window as any).Chart = Chart;
  window.dispatchEvent(new Event('chartjs-ready'));
</script>

<style>
  @media (min-width: 768px) {
    .two-col { grid-template-columns: 1fr 1fr !important; }
    #kpi-cards { grid-template-columns: repeat(4, 1fr) !important; }
  }

  :root {
    --green: #16a34a;
    --red: #dc2626;
  }

  .card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface-raised);
    padding: 16px;
  }

  .kpi {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .kpi-label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-muted);
  }
  .kpi-value {
    font-family: var(--mono);
    font-size: 1.75rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
  }
  .kpi-wow {
    font-family: var(--mono);
    font-size: 0.75rem;
    min-height: 1em;
  }

  .section { margin-bottom: 1.5rem; }
  .section-title {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-muted);
    margin-bottom: 0.5rem;
  }

  .table-wrap { overflow-x: auto; }

  .tbl {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .tbl thead th {
    font-family: var(--mono);
    padding: 7px 12px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-muted);
    border-bottom: 2px solid var(--border);
  }
  .tbl tbody td {
    padding: 7px 12px;
    color: var(--ink-secondary);
    border-bottom: 1px solid var(--border-light);
    font-variant-numeric: tabular-nums;
  }
  .tbl tbody tr:hover { background: var(--surface); }
  .tbl tbody tr:last-child td { border-bottom: none; }

  .period-btn {
    font-family: var(--mono);
    min-height: 36px;
    padding: 0 14px;
    font-size: 12px;
    font-weight: 600;
    background: transparent;
    border: none;
    color: var(--ink-secondary);
    cursor: pointer;
    transition: background 120ms, color 120ms;
  }
  .period-btn:not(:last-child) { border-right: 1px solid var(--border); }
  .period-btn.active { background: #1c1917; color: white; }
  .period-btn:hover:not(.active) { background: var(--surface); }

  .icon-btn {
    font-family: var(--mono);
    min-height: 36px;
    min-width: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface-raised);
    color: var(--ink-secondary);
    cursor: pointer;
    font-size: 1rem;
    transition: background 120ms;
  }
  .icon-btn:hover { background: var(--surface); }

  .csv-btn {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--ink-muted);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .csv-btn:hover { background: var(--surface); color: var(--ink-secondary); }

  .skeleton {
    background: linear-gradient(90deg, var(--surface) 25%, var(--border-light) 50%, var(--surface) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: var(--radius-sm);
    height: 1em;
    display: inline-block;
  }
  @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  .funnel-row { margin-bottom: 0.75rem; }
  .funnel-label { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 4px; }
  .funnel-label span:first-child { font-family: var(--mono); font-weight: 500; color: var(--ink); }
  .funnel-label span:last-child { font-family: var(--mono); font-variant-numeric: tabular-nums; color: var(--ink-secondary); }
  .funnel-track { height: 28px; background: var(--surface); border-radius: var(--radius-lg); overflow: hidden; }
  .funnel-fill { height: 100%; border-radius: var(--radius-lg); transition: width 600ms ease; }

  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  .live-pulse { animation: pulse 1.5s ease-in-out infinite; }

  @media (min-width: 768px) {
    .live-kpi-grid { grid-template-columns: auto auto 1fr !important; }
    .live-bottom-grid { grid-template-columns: 1fr 1fr 1.5fr !important; }
  }
</style>

<script is:inline>
(function() {
  var WORKER = '';
  var apiKey = '';
  var site = '';
  var period = '7d';

  // Session: { sites: [{url, key, site, label}], current: 0 }
  var session = { sites: [], current: 0 };

  var authGate = document.getElementById('auth-gate');
  var dashboard = document.getElementById('dashboard');
  var authForm = document.getElementById('auth-form');
  var authError = document.getElementById('auth-error');
  var siteSwitcher = document.getElementById('site-switcher');

  function applySession() {
    if (!session.sites.length) return;
    var idx = session.current;
    var s = session.sites[idx];
    WORKER = s.url;
    apiKey = s.key;
    site = s.site;
    renderSiteSwitcher();
  }

  function saveSession() {
    sessionStorage.setItem('flarelytics_session', JSON.stringify(session));
  }

  function renderSiteSwitcher() {
    if (session.sites.length <= 1) {
      siteSwitcher.style.display = 'none';
      return;
    }
    siteSwitcher.style.display = '';
    var html = '';
    session.sites.forEach(function(s, i) {
      var label = s.label || s.site;
      html += '<option value="' + i + '"' + (i === session.current ? ' selected' : '') + '>' + esc(label) + '</option>';
    });
    siteSwitcher.innerHTML = html;
  }

  siteSwitcher.addEventListener('change', function() {
    session.current = parseInt(this.value, 10);
    saveSession();
    applySession();
    loadAll();
  });

  // Restore session with backwards-compatibility
  var saved = sessionStorage.getItem('flarelytics_session');
  if (saved) {
    try {
      var raw = JSON.parse(saved);
      // Backwards-compat: old format { url, key, site }
      if (raw && raw.url && !raw.sites) {
        session = {
          sites: [{ url: raw.url, key: raw.key, site: raw.site || '', label: raw.site || '' }],
          current: 0
        };
        saveSession();
      } else if (raw && Array.isArray(raw.sites)) {
        session = raw;
      }
      if (session.sites.length) {
        applySession();
        authGate.style.display = 'none';
        dashboard.style.display = 'block';
        loadAll();
      }
    } catch(e) {}
  }

  // Auth
  authForm.addEventListener('submit', function(e) {
    e.preventDefault();
    var key = document.getElementById('api-key').value.trim();
    var url = document.getElementById('worker-url').value.trim().replace(/\/$/, '');
    var siteInput = document.getElementById('site-hostname').value.trim().replace(/^www\./, '');
    var labelInput = document.getElementById('site-label').value.trim();
    if (!key || !url || !siteInput) return;

    fetch(url + '/query?q=daily-views&period=7d&site=' + encodeURIComponent(siteInput), { headers: { 'X-API-Key': key } })
      .then(function(r) {
        if (r.status === 401) throw new Error('Unauthorized');
        return r.json();
      })
      .then(function() {
        authError.style.display = 'none';

        // Check if url+site already in list
        var existing = -1;
        for (var i = 0; i < session.sites.length; i++) {
          if (session.sites[i].url === url && session.sites[i].site === siteInput) {
            existing = i;
            break;
          }
        }
        if (existing >= 0) {
          session.current = existing;
        } else {
          session.sites.push({ url: url, key: key, site: siteInput, label: labelInput || siteInput });
          session.current = session.sites.length - 1;
        }

        saveSession();
        applySession();
        authGate.style.display = 'none';
        dashboard.style.display = 'block';
        loadAll();
      })
      .catch(function() { authError.style.display = 'block'; });
  });

  // Period buttons
  document.querySelectorAll('.period-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.period-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      period = btn.dataset.period;
      loadAll();
    });
  });

  document.getElementById('refresh-btn').addEventListener('click', loadAll);

  // CSV export
  document.querySelectorAll('.csv-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var table = document.getElementById(btn.dataset.table);
      if (!table) return;
      var rows = [];
      table.querySelectorAll('tr').forEach(function(tr) {
        var cells = [];
        tr.querySelectorAll('th, td').forEach(function(td) { cells.push('"' + td.textContent.replace(/"/g, '""') + '"'); });
        rows.push(cells.join(','));
      });
      var blob = new Blob([rows.join('\n')], { type: 'text/csv' });
      var a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = btn.dataset.table + '-' + period + '.csv';
      a.click();
    });
  });

  // Full CSV export
  document.getElementById('export-btn').addEventListener('click', function() {
    document.querySelectorAll('.csv-btn').forEach(function(btn) { btn.click(); });
  });

  // Funnel event selector
  var funnelEventSelect = document.getElementById('funnel-event-select');
  funnelEventSelect.addEventListener('change', function() {
    loadFunnelByEvent(this.value);
  });

  function query(q) {
    return fetch(WORKER + '/query?q=' + q + '&period=' + period + '&site=' + encodeURIComponent(site), { headers: { 'X-API-Key': apiKey } })
      .then(function(r) { return r.json(); })
      .catch(function() { return null; });
  }

  function queryWow(q) {
    var wowPeriod = period === '7d' ? '14d' : period === '30d' ? '60d' : '180d';
    return fetch(WORKER + '/query?q=' + q + '&period=' + wowPeriod + '&site=' + encodeURIComponent(site), { headers: { 'X-API-Key': apiKey } })
      .then(function(r) { return r.json(); })
      .catch(function() { return null; });
  }

  var tablePages = {};
  var tableData = {};
  var PAGE_SIZE = 10;

  function rows(d) { return d && Array.isArray(d) ? d : (d && d.data ? d.data : []); }
  function num(n) { return n == null || isNaN(n) ? '0' : Math.round(n).toLocaleString('en-US'); }
  function esc(s) { return s == null ? '' : String(s).replace(/[&<>"']/g, function(m) { return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]; }); }
  function skel(w) { return '<span class="skeleton" style="width:' + (w||60) + 'px">&nbsp;</span>'; }
  function sum(arr, f) { return arr.reduce(function(a, r) { return a + (parseFloat(r[f]) || 0); }, 0); }

  function renderPagination(id, page, total) {
    var pages = Math.ceil(total / PAGE_SIZE);
    var wrap = document.getElementById(id);
    if (!wrap) return;
    var tableWrap = wrap.closest('.table-wrap');
    if (!tableWrap) return;
    var el = document.getElementById('pag-' + id);
    if (pages <= 1) {
      if (el) el.remove();
      return;
    }
    if (!el) {
      el = document.createElement('div');
      el.id = 'pag-' + id;
      el.style.cssText = 'display:flex;justify-content:space-between;align-items:center;padding:0.5rem 0;font-family:var(--mono);font-size:0.75rem;color:var(--ink-muted);';
      tableWrap.appendChild(el);
    }
    var start = page * PAGE_SIZE + 1;
    var end = Math.min((page + 1) * PAGE_SIZE, total);
    el.innerHTML =
      '<span>' + start + '\u2013' + end + ' / ' + total + '</span>' +
      '<span style="display:flex;gap:0.5rem;">' +
      '<button onclick="tablePrev(\'' + id + '\')" ' + (page === 0 ? 'disabled' : '') + ' style="background:none;border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:var(--mono);cursor:pointer;">\u2190</button>' +
      '<button onclick="tableNext(\'' + id + '\',' + pages + ')" ' + (page >= pages - 1 ? 'disabled' : '') + ' style="background:none;border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:var(--mono);cursor:pointer;">\u2192</button>' +
      '</span>';
  }

  window.tablePrev = function(id) {
    tablePages[id] = Math.max(0, (tablePages[id] || 0) - 1);
    if (id === 'table-pages') {
      var saved = tableData['table-pages'];
      if (saved) fillTopPages(saved.pagesData, saved.eventsData, tablePages['table-pages']);
      return;
    }
    var saved = tableData[id];
    if (saved) fillTable(id, saved.data, saved.cols, true);
  };
  window.tableNext = function(id, pages) {
    tablePages[id] = Math.min(pages - 1, (tablePages[id] || 0) + 1);
    if (id === 'table-pages') {
      var saved = tableData['table-pages'];
      if (saved) fillTopPages(saved.pagesData, saved.eventsData, tablePages['table-pages']);
      return;
    }
    var saved = tableData[id];
    if (saved) fillTable(id, saved.data, saved.cols, true);
  };

  function computeWow(allRows, valueField) {
    if (!allRows.length) return null;
    // Sort by date ascending
    var sorted = allRows.slice().sort(function(a, b) {
      return (a.date || '') < (b.date || '') ? -1 : 1;
    });
    var half = Math.floor(sorted.length / 2);
    if (half === 0) return null;
    var prev = sorted.slice(0, half);
    var curr = sorted.slice(sorted.length - half);
    var prevSum = sum(prev, valueField);
    var currSum = sum(curr, valueField);
    if (prevSum === 0) return null;
    return ((currSum - prevSum) / prevSum) * 100;
  }

  function renderWow(selector, pct) {
    var el = document.querySelector(selector);
    if (!el) return;
    if (pct == null) { el.textContent = ''; return; }
    var sign = pct >= 0 ? '+' : '';
    el.textContent = sign + pct.toFixed(1) + '%';
    el.style.color = pct >= 0 ? 'var(--green)' : 'var(--red)';
    el.style.fontFamily = 'var(--mono)';
    el.style.fontSize = '0.75rem';
  }

  function fmtSeconds(s) {
    var n = Math.round(s);
    if (n < 60) return n + 's';
    return Math.floor(n / 60) + 'm ' + (n % 60) + 's';
  }

  function fillTimingTable(data) {
    var tbody = document.querySelector('#table-timing tbody');
    if (!tbody) return;
    var r = rows(data);
    if (!r.length) { tbody.innerHTML = '<tr><td colspan="3" style="padding:2rem;text-align:center;color:var(--ink-muted);">No data — timing events accumulate as visitors browse</td></tr>'; return; }
    var html = '';
    r.forEach(function(row) {
      html += '<tr><td style="font-family:var(--mono);font-size:0.8125rem;">' + esc(row.path) + '</td>';
      html += '<td style="text-align:right;font-family:var(--mono);font-variant-numeric:tabular-nums;">' + fmtSeconds(parseFloat(row.avg_seconds) || 0) + '</td>';
      html += '<td style="text-align:right;font-family:var(--mono);font-variant-numeric:tabular-nums;">' + num(row.sessions) + '</td></tr>';
    });
    tbody.innerHTML = html;
  }

  function renderDeviceBadges(data) {
    var el = document.getElementById('device-badges');
    if (!el) return;
    var r = rows(data);
    if (!r.length) { el.innerHTML = ''; return; }
    var icons = { mobile: '📱', tablet: '⬜', desktop: '💻' };
    var total = r.reduce(function(a, row) { return a + (parseFloat(row.views) || 0); }, 0);
    el.innerHTML = r.map(function(row) {
      var pct = total > 0 ? Math.round((parseFloat(row.views) || 0) / total * 100) : 0;
      return '<span style="font-family:var(--mono);font-size:0.75rem;color:var(--ink-secondary);white-space:nowrap;">' + (icons[row.device] || '?') + ' ' + row.device + ' ' + pct + '%</span>';
    }).join('');
  }

  function computeMaxVals(allRows, cols) {
    var maxVals = {};
    cols.forEach(function(c) {
      if (c.fmt === 'num') {
        maxVals[c.key] = Math.max.apply(null, allRows.map(function(row) { return parseFloat(row[c.key]) || 0; }));
      }
    });
    return maxVals;
  }

  function renderTableRows(r, cols, maxVals) {
    var html = '';
    r.forEach(function(row) {
      html += '<tr>';
      cols.forEach(function(c) {
        var v = row[c.key];
        var align = c.align || 'left';
        var styleAttr = 'text-align:' + align;

        if (c.favicon) {
          var rawVal = v == null ? '' : String(v);
          var faviconUrl = 'https://www.google.com/s2/favicons?sz=16&domain=' + esc(rawVal);
          html += '<td style="font-family:var(--mono);font-size:0.8125rem;">' +
            '<span style="display:flex;align-items:center;gap:0.375rem;">' +
            '<img src="' + faviconUrl + '" width="16" height="16" style="border-radius:2px;flex-shrink:0;" onerror="this.style.display=\'none\'">' +
            esc(rawVal) + '</span></td>';
        } else if (c.fmt === 'num') {
          var rawNum = parseFloat(row[c.key]) || 0;
          var pct = (maxVals && maxVals[c.key] > 0) ? rawNum / maxVals[c.key] * 100 : 0;
          var bg = 'background:linear-gradient(to right,rgba(217,119,6,0.15) ' + pct + '%,transparent ' + pct + '%)';
          html += '<td style="' + styleAttr + ';' + bg + '">' + num(v) + '</td>';
        } else if (c.fmt === 'pct') {
          html += '<td style="' + styleAttr + '">' + (parseFloat(v) || 0).toFixed(1) + '%</td>';
        } else if (c.fmt === 'props') {
          var rawStr = v == null ? '' : String(v).trim();
          if (!rawStr) {
            html += '<td style="' + styleAttr + '">-</td>';
          } else {
            var parts = rawStr.split('|').filter(function(p) { return p.trim(); });
            var tags = parts.map(function(p) {
              return '<span style="display:inline-block;background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:1px 6px;font-family:var(--mono);font-size:11px;color:var(--ink-secondary);margin:1px 2px 1px 0;">' + esc(p.trim()) + '</span>';
            }).join('');
            html += '<td style="' + styleAttr + '">' + tags + '</td>';
          }
        } else {
          html += '<td style="' + styleAttr + '">' + (esc(v) || '-') + '</td>';
        }
      });
      html += '</tr>';
    });
    return html;
  }

  function fillTable(id, data, cols, paginated) {
    var tbody = document.querySelector('#' + id + ' tbody');
    if (!tbody) return;
    var allRows = rows(data);
    if (paginated) {
      tableData[id] = { data: data, cols: cols };
      var page = tablePages[id] || 0;
      var total = allRows.length;
      var start = page * PAGE_SIZE;
      var r = allRows.slice(start, start + PAGE_SIZE);
      if (!allRows.length) {
        tbody.innerHTML = '<tr><td colspan="' + cols.length + '" style="padding:2rem;text-align:center;color:var(--ink-muted);">No data</td></tr>';
        renderPagination(id, 0, 0);
        return;
      }
      var maxVals = computeMaxVals(allRows, cols);
      tbody.innerHTML = renderTableRows(r, cols, maxVals);
      renderPagination(id, page, total);
      return;
    }
    var r = allRows;
    if (!r.length) { tbody.innerHTML = '<tr><td colspan="' + cols.length + '" style="padding:2rem;text-align:center;color:var(--ink-muted);">No data</td></tr>'; return; }
    var maxVals = computeMaxVals(r, cols);
    tbody.innerHTML = renderTableRows(r, cols, maxVals);
  }

  function fillTopPages(pagesData, eventsData, page) {
    var allPageRows = rows(pagesData);
    var eventRows = rows(eventsData);
    if (page === undefined) page = tablePages['table-pages'] || 0;
    tableData['table-pages'] = { pagesData: pagesData, eventsData: eventsData };

    // Build share map from custom events
    var shareMap = {};
    var hasShares = false;
    eventRows.forEach(function(row) {
      if (row.event === 'share' && row.properties) {
        var url;
        try {
          var parts = String(row.properties).split('|');
          var rawUrl = parts[1] || '';
          if (rawUrl) {
            var u = new URL(rawUrl);
            url = u.pathname;
          }
        } catch(e) {
          url = null;
        }
        if (url) {
          hasShares = true;
          shareMap[url] = (shareMap[url] || 0) + (parseFloat(row.count) || 1);
        }
      }
    });

    var thead = document.querySelector('#table-pages thead tr');
    var tbody = document.querySelector('#table-pages tbody');
    if (!thead || !tbody) return;

    if (hasShares) {
      thead.innerHTML = '<th style="text-align:left;">Path</th><th style="text-align:right;">Views</th><th style="text-align:right;">Visitors</th><th style="text-align:right;">Jaot</th>';
    } else {
      thead.innerHTML = '<th style="text-align:left;">Path</th><th style="text-align:right;">Views</th><th style="text-align:right;">Visitors</th>';
    }

    var colCount = hasShares ? 4 : 3;

    if (!allPageRows.length) {
      tbody.innerHTML = '<tr><td colspan="' + colCount + '" style="padding:2rem;text-align:center;color:var(--ink-muted);">No data</td></tr>';
      renderPagination('table-pages', 0, 0);
      return;
    }

    var total = allPageRows.length;
    var start = page * PAGE_SIZE;
    var pageRows = allPageRows.slice(start, start + PAGE_SIZE);

    var html = '';
    pageRows.forEach(function(row) {
      var path = esc(row.path) || '-';
      var views = num(row.views);
      var visitors = num(row.visitors);
      html += '<tr style="cursor:pointer;" onclick="openDrilldown(\'' + esc(row.path).replace(/'/g, "\\'") + '\')"><td style="text-align:left;">' + path + '</td><td style="text-align:right;">' + views + '</td><td style="text-align:right;">' + visitors + '</td>';
      if (hasShares) {
        var shares = shareMap[row.path] || 0;
        html += '<td style="text-align:right;">' + (shares > 0 ? num(shares) : '-') + '</td>';
      }
      html += '</tr>';
    });
    tbody.innerHTML = html;
    renderPagination('table-pages', page, total);
  }

  var INTERNAL_EVENTS = { scroll_depth: true, timing: true };

  function fillTopStories(storiesData) {
    var storyRows = rows(storiesData);
    var section = document.getElementById('section-top-stories');
    if (!section) return;
    if (!storyRows.length) {
      section.style.display = 'none';
      return;
    }
    section.style.display = '';
    var tbody = document.querySelector('#table-stories tbody');
    if (!tbody) return;
    var maxViews = Math.max.apply(null, storyRows.map(function(r) { return parseFloat(r.views) || 0; }));
    if (maxViews === 0) maxViews = 1;
    var html = '';
    storyRows.slice(0, 10).forEach(function(row) {
      var pct = Math.round(((parseFloat(row.views) || 0) / maxViews) * 100);
      html += '<tr style="cursor:pointer;" onclick="openDrilldown(\'' + esc(row.path).replace(/'/g, "\\'") + '\')">';
      html += '<td style="text-align:left;">' + esc(row.path) + '</td>';
      html += '<td style="text-align:right;">' + num(row.views) + '</td>';
      html += '<td style="text-align:right;">' + num(row.visitors) + '</td>';
      html += '<td style="width:80px;padding-right:12px;"><div style="background:var(--surface);border-radius:4px;overflow:hidden;height:6px;"><div style="background:var(--accent);height:100%;width:' + pct + '%;border-radius:4px;"></div></div></td>';
      html += '</tr>';
    });
    tbody.innerHTML = html;
  }

  function populateFunnelEventSelect(eventsData) {
    var eventRows = rows(eventsData);
    var names = {};
    eventRows.forEach(function(row) {
      if (row.event && !INTERNAL_EVENTS[row.event]) names[row.event] = true;
    });
    var select = document.getElementById('funnel-event-select');
    var html = '<option value="">Kaikki eventit</option>';
    Object.keys(names).sort().forEach(function(name) {
      html += '<option value="' + esc(name) + '">' + esc(name) + '</option>';
    });
    select.innerHTML = html;
