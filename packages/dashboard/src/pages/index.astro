      var pct = Math.max(4, Math.round(((parseFloat(row.views) || 0) / max) * 100));
      html += '<div style="margin-bottom:6px;">';
      html += '<div style="display:flex;justify-content:space-between;font-size:11px;margin-bottom:2px;">';
      html += '<span style="font-family:var(--mono);color:var(--ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:80%;">' + esc(row.path) + '</span>';
      html += '<span style="font-family:var(--mono);color:var(--ink-muted);font-variant-numeric:tabular-nums;flex-shrink:0;margin-left:8px;">' + num(row.views) + '</span>';
      html += '</div>';
      html += '<div style="background:var(--surface);border-radius:3px;overflow:hidden;height:4px;"><div style="background:var(--accent);height:100%;width:' + pct + '%;border-radius:3px;"></div></div>';
      html += '</div>';
    });
    el.innerHTML = html;
  }

  function renderLiveReferrers(refData) {
    var el = document.getElementById('live-referrers-list');
    if (!el) return;
    var r = rows(refData);
    if (!r.length) { el.innerHTML = '<div style="color:var(--ink-muted);font-family:var(--mono);font-size:11px;">Direct / no referrer</div>'; return; }
    var max = parseFloat(r[0].visits) || 1;
    var html = '';
    r.slice(0, 6).forEach(function(row) {
      var pct = Math.max(4, Math.round(((parseFloat(row.visits) || 0) / max) * 100));
      var host = esc(row.referrer || 'direct');
      html += '<div style="margin-bottom:6px;">';
      html += '<div style="display:flex;justify-content:space-between;font-size:11px;margin-bottom:2px;">';
      html += '<span style="font-family:var(--mono);color:var(--ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:80%;">' + host + '</span>';
      html += '<span style="font-family:var(--mono);color:var(--ink-muted);font-variant-numeric:tabular-nums;flex-shrink:0;margin-left:8px;">' + num(row.visits) + '</span>';
      html += '</div>';
      html += '<div style="background:var(--surface);border-radius:3px;overflow:hidden;height:4px;"><div style="background:var(--accent-hover);height:100%;width:' + pct + '%;border-radius:3px;"></div></div>';
      html += '</div>';
    });
    el.innerHTML = html;
  }

  function loadLive() {
    if (!liveActive) return;
    var pulse = document.getElementById('live-pulse');
    if (pulse) { pulse.classList.add('live-pulse'); }

    Promise.all([
      liveQuery('live-visitors'),
      liveQuery('live-pages'),
      liveQuery('hourly-today'),
      liveQuery('live-referrers')
    ]).then(function(results) {
      var visitorData = rows(results[0]);
      var pagesData = results[1];
      var hourlyData = results[2];
      var referrersData = results[3];

      var visitors = visitorData.length ? (visitorData[0].visitors || 0) : 0;
      var pageviews = visitorData.length ? (visitorData[0].pageviews || 0) : 0;

      var vEl = document.getElementById('live-visitors');
      var pvEl = document.getElementById('live-pageviews');
      var updEl = document.getElementById('live-updated');

      if (vEl) vEl.textContent = num(visitors);
      if (pvEl) pvEl.textContent = num(pageviews);

      var now = new Date();
      var hh = String(now.getHours()).padStart(2, '0');
      var mm = String(now.getMinutes()).padStart(2, '0');
      var ss = String(now.getSeconds()).padStart(2, '0');
      if (updEl) updEl.textContent = 'Updated ' + hh + ':' + mm + ':' + ss;

      renderLivePages(pagesData);
      renderLiveReferrers(referrersData);
      renderLiveChart(hourlyData);

      if (pulse) { pulse.classList.remove('live-pulse'); }
      if (liveActive) { liveTimer = setTimeout(loadLive, 60000); }
    });
  }

  function startLive() {
    liveActive = true;
    var panel = document.getElementById('live-panel');
    var btn = document.getElementById('live-btn');
    var dot = document.getElementById('live-dot');
    if (panel) panel.style.display = '';
    if (btn) { btn.style.background = '#1c1917'; btn.style.color = 'white'; }
    if (dot) { dot.style.background = 'white'; }
    loadLive();
  }

  function stopLive() {
    liveActive = false;
    if (liveTimer) { clearTimeout(liveTimer); liveTimer = null; }
    destroyChart('live-chart');
    var panel = document.getElementById('live-panel');
    var btn = document.getElementById('live-btn');
    var dot = document.getElementById('live-dot');
    if (panel) panel.style.display = 'none';
    if (btn) { btn.style.background = ''; btn.style.color = ''; }
    if (dot) { dot.style.background = '#dc2626'; }
  }

  document.getElementById('live-btn').addEventListener('click', function() {
    if (liveActive) { stopLive(); } else { startLive(); }
  });
  // ---- end live panel ----

  function renderFunnel(data) {
    var el = document.getElementById('funnel');
    var r = rows(data);
    if (!r.length) { el.innerHTML = '<div style="padding:2rem;text-align:center;color:var(--ink-muted);font-family:var(--mono);font-size:12px;">No funnel data</div>'; return; }

    var pv = sum(r, 'pageviews');
    var conv = sum(r, 'conversions');
    var max = Math.max(pv, 1);

    var steps = [
      { label: 'Pageviews', value: pv, color: 'var(--accent)' },
      { label: 'Custom Events', value: conv, color: 'var(--green)' },
    ];

    var html = '';
    steps.forEach(function(s) {
      var w = Math.max(2, (s.value / max) * 100);
      var rate = pv > 0 ? (s.value / pv * 100).toFixed(2) : '0';
      html += '<div class="funnel-row">';
      html += '<div class="funnel-label"><span>' + esc(s.label) + '</span><span>' + num(s.value) + ' (' + rate + '%)</span></div>';
      html += '<div class="funnel-track"><div class="funnel-fill" style="width:' + w + '%;background:' + s.color + ';opacity:0.8;"></div></div>';
      html += '</div>';
    });
    el.innerHTML = html;
  }
})();
</script>
